# Variáveis de produção da API — copie para .env no Coolify ou localmente
# cp .env.example .env

NODE_ENV=production

# Segurança (mínimo 32 caracteres — gere com: openssl rand -base64 48)
JWT_SECRET=ALTERAR_JWT_SECRET

# Frontend / CORS
FRONTEND_URL=https://app.giftmed.org
FRONTEND_ORIGIN=https://app.giftmed.org

# Banco PostgreSQL + Prisma
DATABASE_URL=postgresql://usuario:senha@host:5432/giftmed_sys?sslmode=require&connect_timeout=30
DIRECT_URL=postgresql://usuario:senha@host:5432/giftmed_sys?sslmode=require&connect_timeout=30

# SMTP / recuperação de senha
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ALTERAR_EMAIL_SMTP
SMTP_PASS=ALTERAR_SENHA_SMTP
SMTP_FROM=ALTERAR_EMAIL_REMETENTE

# WhatsApp (desabilitado por padrão em produção)
USE_WHATSAPP_BUSINESS_API=false
USE_WHATSAPP_MCP=false
AUTO_INIT_WHATSAPP=false
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Opcional — Coolify define PORT automaticamente
# PORT=3333
# HOST=0.0.0.0
